{
    "rules": {
        "spacing": {
            "threshold": 4.0
        },
        "thermal": {
            "threshold": 6.0,
            "hot_keywords": [
                "regulator",
                "mosfet",
                "driver",
                "buck",
                "boost",
                "ldo"
            ]
        },
        "power_rail": {
            "min_connections": 3,
            "max_trace_length": 60.0,
            "min_trace_width": 0.3,
            "max_via_count": 4
        },
        "signal_path": {
            "threshold": 30.0,
            "critical_net_keywords": [
                "CLK",
                "CTRL",
                "RESET",
                "TX",
                "RX",
                "SCL",
                "SDA"
            ]
        },
        "return_path": {
            "min_ground_zones": 1,
            "require_ground_net": true
        },
        "trace_quality": {
            "max_signal_trace_length": 100.0,
            "min_general_trace_width": 0.18
        }
    }
}