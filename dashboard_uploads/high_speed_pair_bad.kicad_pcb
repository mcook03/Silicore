(kicad_pcb
  (net 0 "")
  (net 1 "USB_DP")
  (net 2 "USB_DN")
  (net 3 "GND")
  (net 4 "VBUS")
  (net 5 "CLK")

  (footprint "USB_Connector"
    (layer "F.Cu")
    (at 8 20 0)
    (property "Reference" "J1")
    (property "Value" "usb_c")
    (pad 1 smd rect (at 0 0) (size 1.2 1.0) (layers "F.Cu") (net 4 "VBUS"))
    (pad 2 smd rect (at 0 1.8) (size 1.0 1.0) (layers "F.Cu") (net 1 "USB_DP"))
    (pad 3 smd rect (at 0 3.6) (size 1.0 1.0) (layers "F.Cu") (net 2 "USB_DN"))
    (pad 4 smd rect (at 0 5.4) (size 1.2 1.0) (layers "F.Cu") (net 3 "GND"))
  )

  (footprint "MCU"
    (layer "F.Cu")
    (at 92 22 0)
    (property "Reference" "U1")
    (property "Value" "mcu")
    (pad 1 smd rect (at 0 0) (size 1.1 1.1) (layers "F.Cu") (net 1 "USB_DP"))
    (pad 2 smd rect (at 0 2.2) (size 1.1 1.1) (layers "F.Cu") (net 2 "USB_DN"))
    (pad 3 smd rect (at 0 4.4) (size 1.1 1.1) (layers "F.Cu") (net 3 "GND"))
    (pad 4 smd rect (at 0 6.6) (size 1.1 1.1) (layers "F.Cu") (net 5 "CLK"))
  )

  (footprint "Crystal"
    (layer "F.Cu")
    (at 78 36 0)
    (property "Reference" "Y1")
    (property "Value" "24MHz")
    (pad 1 smd rect (at 0 0) (size 1.0 1.0) (layers "F.Cu") (net 5 "CLK"))
    (pad 2 smd rect (at 2 0) (size 1.0 1.0) (layers "F.Cu") (net 3 "GND"))
  )

  (segment (start 8 21.8) (end 26 21.8) (width 0.18) (layer "F.Cu") (net 1))
  (segment (start 26 21.8) (end 52 26.5) (width 0.18) (layer "F.Cu") (net 1))
  (segment (start 52 26.5) (end 92 22) (width 0.18) (layer "F.Cu") (net 1))

  (segment (start 8 23.6) (end 22 23.6) (width 0.18) (layer "F.Cu") (net 2))
  (segment (start 22 23.6) (end 22 41) (width 0.18) (layer "F.Cu") (net 2))
  (segment (start 22 41) (end 64 41) (width 0.18) (layer "F.Cu") (net 2))
  (segment (start 64 41) (end 64 24.2) (width 0.18) (layer "F.Cu") (net 2))
  (segment (start 64 24.2) (end 92 24.2) (width 0.18) (layer "F.Cu") (net 2))

  (segment (start 78 36) (end 92 28.6) (width 0.12) (layer "F.Cu") (net 5))
  (segment (start 8 25.4) (end 92 26.4) (width 0.20) (layer "F.Cu") (net 3))
  (segment (start 8 20) (end 92 18) (width 0.25) (layer "F.Cu") (net 4))

  (via (at 30 22) (size 0.8) (drill 0.4) (net 1))
  (via (at 54 26.5) (size 0.8) (drill 0.4) (net 1))
  (via (at 22 30) (size 0.8) (drill 0.4) (net 2))
  (via (at 64 33) (size 0.8) (drill 0.4) (net 2))
)
