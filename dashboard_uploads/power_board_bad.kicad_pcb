(kicad_pcb
  (net 0 "")
  (net 1 "VIN")
  (net 2 "GND")
  (net 3 "CTRL")

  (footprint "Regulator"
    (layer "F.Cu")
    (at 10 10 0)
    (property "Reference" "U1")
    (property "Value" "regulator")
    (pad 1 smd rect (at 0 0) (size 1.2 1.2) (layers "F.Cu") (net 1 "VIN"))
    (pad 2 smd rect (at 2 0) (size 1.2 1.2) (layers "F.Cu") (net 2 "GND"))
  )

  (footprint "MCU"
    (layer "F.Cu")
    (at 95 10 0)
    (property "Reference" "U2")
    (property "Value" "mcu")
    (pad 1 smd rect (at 0 0) (size 1.0 1.0) (layers "F.Cu") (net 1 "VIN"))
    (pad 2 smd rect (at 2 0) (size 1.0 1.0) (layers "F.Cu") (net 2 "GND"))
    (pad 3 smd rect (at 1 2) (size 1.0 1.0) (layers "F.Cu") (net 3 "CTRL"))
  )

  (segment (start 10 10) (end 40 10) (width 0.15) (layer "F.Cu") (net 1))
  (segment (start 40 10) (end 70 10) (width 0.15) (layer "F.Cu") (net 1))
  (segment (start 70 10) (end 95 10) (width 0.15) (layer "F.Cu") (net 1))
  (segment (start 10 12) (end 95 12) (width 0.12) (layer "F.Cu") (net 2))
  (segment (start 95 12) (end 96 14) (width 0.10) (layer "F.Cu") (net 3))

  (via (at 25 10) (size 0.8) (drill 0.4) (net 1))
  (via (at 35 10) (size 0.8) (drill 0.4) (net 1))
  (via (at 45 10) (size 0.8) (drill 0.4) (net 1))
  (via (at 55 10) (size 0.8) (drill 0.4) (net 1))
  (via (at 65 10) (size 0.8) (drill 0.4) (net 1))
  (via (at 75 10) (size 0.8) (drill 0.4) (net 1))
  (via (at 85 10) (size 0.8) (drill 0.4) (net 1))
)