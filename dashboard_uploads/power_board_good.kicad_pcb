(kicad_pcb
  (net 0 "")
  (net 1 "VIN")
  (net 2 "GND")
  (net 3 "CTRL")

  (footprint "Regulator"
    (layer "F.Cu")
    (at 20 20 0)
    (property "Reference" "U1")
    (property "Value" "regulator")
    (pad 1 smd rect (at 0 0) (size 1.2 1.2) (layers "F.Cu") (net 1 "VIN"))
    (pad 2 smd rect (at 2 0) (size 1.2 1.2) (layers "F.Cu") (net 2 "GND"))
  )

  (footprint "MCU"
    (layer "F.Cu")
    (at 35 20 0)
    (property "Reference" "U2")
    (property "Value" "mcu")
    (pad 1 smd rect (at 0 0) (size 1.0 1.0) (layers "F.Cu") (net 1 "VIN"))
    (pad 2 smd rect (at 2 0) (size 1.0 1.0) (layers "F.Cu") (net 2 "GND"))
    (pad 3 smd rect (at 1 2) (size 1.0 1.0) (layers "F.Cu") (net 3 "CTRL"))
  )

  (footprint "Capacitor"
    (layer "F.Cu")
    (at 33 18 0)
    (property "Reference" "C1")
    (property "Value" "cap")
    (pad 1 smd rect (at 0 0) (size 1.0 1.0) (layers "F.Cu") (net 1 "VIN"))
    (pad 2 smd rect (at 1 0) (size 1.0 1.0) (layers "F.Cu") (net 2 "GND"))
  )

  (segment (start 20 20) (end 28 20) (width 0.60) (layer "F.Cu") (net 1))
  (segment (start 28 20) (end 35 20) (width 0.60) (layer "F.Cu") (net 1))
  (segment (start 20 22) (end 35 22) (width 0.50) (layer "F.Cu") (net 2))
  (segment (start 35 22) (end 36 24) (width 0.20) (layer "F.Cu") (net 3))

  (via (at 30 20) (size 0.8) (drill 0.4) (net 1))
  (zone (net_name "GND") (layer "F.Cu"))
)