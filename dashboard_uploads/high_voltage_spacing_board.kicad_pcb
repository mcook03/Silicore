(kicad_pcb
  (net 0 "")
  (net 1 "HV+")
  (net 2 "HV-")
  (net 3 "GND")
  (net 4 "CTRL")

  (footprint "Input"
    (layer "F.Cu")
    (at 14 18 0)
    (property "Reference" "J1")
    (property "Value" "hv_input")
    (pad 1 smd rect (at 0 0) (size 1.4 1.4) (layers "F.Cu") (net 1 "HV+"))
    (pad 2 smd rect (at 2.1 0) (size 1.4 1.4) (layers "F.Cu") (net 2 "HV-"))
  )

  (footprint "IsoDriver"
    (layer "F.Cu")
    (at 26 18 0)
    (property "Reference" "U1")
    (property "Value" "driver")
    (pad 1 smd rect (at 0 0) (size 1.1 1.1) (layers "F.Cu") (net 1 "HV+"))
    (pad 2 smd rect (at 1.8 0) (size 1.1 1.1) (layers "F.Cu") (net 2 "HV-"))
    (pad 3 smd rect (at 0.9 2) (size 1.1 1.1) (layers "F.Cu") (net 4 "CTRL"))
  )

  (footprint "MCU"
    (layer "F.Cu")
    (at 48 20 0)
    (property "Reference" "U2")
    (property "Value" "mcu")
    (pad 1 smd rect (at 0 0) (size 1.0 1.0) (layers "F.Cu") (net 4 "CTRL"))
    (pad 2 smd rect (at 2 0) (size 1.0 1.0) (layers "F.Cu") (net 3 "GND"))
  )

  (segment (start 14 18) (end 26 18) (width 0.24) (layer "F.Cu") (net 1))
  (segment (start 16.1 18) (end 27.8 18) (width 0.24) (layer "F.Cu") (net 2))
  (segment (start 26.9 20) (end 48 20) (width 0.16) (layer "F.Cu") (net 4))
  (segment (start 50 20) (end 62 20) (width 0.18) (layer "F.Cu") (net 3))
)
