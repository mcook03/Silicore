(kicad_pcb
  (net 0 "")
  (net 1 "VCC")
  (net 2 "GND")
  (net 3 "SWDIO")
  (net 4 "SWCLK")
  (net 5 "UART_TX")

  (footprint "MCU"
    (layer "F.Cu")
    (at 36 24 0)
    (property "Reference" "U1")
    (property "Value" "mcu")
    (pad 1 smd rect (at 0 0) (size 1.0 1.0) (layers "F.Cu") (net 1 "VCC"))
    (pad 2 smd rect (at 2 0) (size 1.0 1.0) (layers "F.Cu") (net 2 "GND"))
    (pad 3 smd rect (at 0 2) (size 1.0 1.0) (layers "F.Cu") (net 3 "SWDIO"))
    (pad 4 smd rect (at 2 2) (size 1.0 1.0) (layers "F.Cu") (net 4 "SWCLK"))
    (pad 5 smd rect (at 1 4) (size 1.0 1.0) (layers "F.Cu") (net 5 "UART_TX"))
  )

  (footprint "Header"
    (layer "F.Cu")
    (at 72 12 0)
    (property "Reference" "J1")
    (property "Value" "io_header")
    (pad 1 smd rect (at 0 0) (size 1.1 1.1) (layers "F.Cu") (net 5 "UART_TX"))
    (pad 2 smd rect (at 2 0) (size 1.1 1.1) (layers "F.Cu") (net 2 "GND"))
  )

  (footprint "Cap"
    (layer "F.Cu")
    (at 38 18 0)
    (property "Reference" "C1")
    (property "Value" "100n")
    (pad 1 smd rect (at 0 0) (size 0.9 0.9) (layers "F.Cu") (net 1 "VCC"))
    (pad 2 smd rect (at 1 0) (size 0.9 0.9) (layers "F.Cu") (net 2 "GND"))
  )

  (footprint "Res"
    (layer "F.Cu")
    (at 40 24 0)
    (property "Reference" "R1")
    (property "Value" "22R")
    (pad 1 smd rect (at 0 0) (size 0.8 0.8) (layers "F.Cu") (net 5 "UART_TX"))
    (pad 2 smd rect (at 1 0) (size 0.8 0.8) (layers "F.Cu") (net 2 "GND"))
  )

  (segment (start 36 24) (end 38 18) (width 0.16) (layer "F.Cu") (net 1))
  (segment (start 38 24) (end 41 24) (width 0.12) (layer "F.Cu") (net 5))
  (segment (start 41 24) (end 72 12) (width 0.12) (layer "F.Cu") (net 5))
  (segment (start 38 26) (end 66 30) (width 0.10) (layer "F.Cu") (net 4))
  (segment (start 36 26) (end 66 34) (width 0.10) (layer "F.Cu") (net 3))
  (segment (start 38 18) (end 39 18) (width 0.14) (layer "F.Cu") (net 2))
)
