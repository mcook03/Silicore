(kicad_pcb
  (net 0 "")
  (net 1 "VIN")
  (net 2 "GND")
  (net 3 "ADC_IN")
  (net 4 "SW")
  (net 5 "SENSOR_OUT")

  (footprint "BuckReg"
    (layer "F.Cu")
    (at 18 16 0)
    (property "Reference" "U1")
    (property "Value" "buck")
    (pad 1 smd rect (at 0 0) (size 1.2 1.2) (layers "F.Cu") (net 1 "VIN"))
    (pad 2 smd rect (at 2 0) (size 1.2 1.2) (layers "F.Cu") (net 4 "SW"))
    (pad 3 smd rect (at 4 0) (size 1.2 1.2) (layers "F.Cu") (net 2 "GND"))
  )

  (footprint "Inductor"
    (layer "F.Cu")
    (at 28 15 0)
    (property "Reference" "L1")
    (property "Value" "10uH")
    (pad 1 smd rect (at 0 0) (size 1.3 1.3) (layers "F.Cu") (net 4 "SW"))
    (pad 2 smd rect (at 3 0) (size 1.3 1.3) (layers "F.Cu") (net 1 "VIN"))
  )

  (footprint "ADC"
    (layer "F.Cu")
    (at 42 18 0)
    (property "Reference" "U2")
    (property "Value" "adc")
    (pad 1 smd rect (at 0 0) (size 1.0 1.0) (layers "F.Cu") (net 3 "ADC_IN"))
    (pad 2 smd rect (at 2 0) (size 1.0 1.0) (layers "F.Cu") (net 2 "GND"))
    (pad 3 smd rect (at 1 2) (size 1.0 1.0) (layers "F.Cu") (net 5 "SENSOR_OUT"))
  )

  (footprint "Sensor"
    (layer "F.Cu")
    (at 55 20 0)
    (property "Reference" "U3")
    (property "Value" "sensor")
    (pad 1 smd rect (at 0 0) (size 1.0 1.0) (layers "F.Cu") (net 5 "SENSOR_OUT"))
    (pad 2 smd rect (at 2 0) (size 1.0 1.0) (layers "F.Cu") (net 2 "GND"))
  )

  (segment (start 18 16) (end 28 15) (width 0.22) (layer "F.Cu") (net 4))
  (segment (start 18 18) (end 55 22) (width 0.16) (layer "F.Cu") (net 2))
  (segment (start 42 18) (end 55 20) (width 0.12) (layer "F.Cu") (net 3))
  (segment (start 55 20) (end 43 20) (width 0.12) (layer "F.Cu") (net 5))
  (segment (start 18 16) (end 60 14) (width 0.18) (layer "F.Cu") (net 1))
)
